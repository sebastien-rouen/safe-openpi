# ============================================================
# JIRA Dashboard - Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs réelles.
# Ne jamais committer .env dans le dépôt.
# ============================================================

# --- Connexion JIRA ---
JIRA_URL=https://votre-jira.atlassian.net
JIRA_USER=votre-email@example.com
JIRA_TOKEN=votre-token-jira
JIRA_PROJECT=PROJ,PROJ2,PROJ3
